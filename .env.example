# Weather API keys — the system works without these using free sources (Open-Meteo, wttr.in)
OPENWEATHER_API_KEY=your_key_here
WEATHERAPI_KEY=your_key_here
VISUAL_CROSSING_KEY=your_key_here
ECMWF_API_KEY=your_ecmwf_cds_key_here

# Server security — SET THIS before exposing to a network!
# Without this, anyone can add/delete cities and flush the cache.
WEATHER_API_KEY=your_secret_key_here

# Server config
WEATHER_PORT=5000
WEATHER_HOST=0.0.0.0

# CORS — comma-separated origins. Leave empty to auto-detect all local IPs.
# Example for production: CORS_ORIGINS=https://weather.yourdomain.com
CORS_ORIGINS=

# Max request body size in bytes (default: 1MB)
WEATHER_MAX_BODY=1048576
